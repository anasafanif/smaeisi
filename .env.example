# Copy to .env.local and fill in values, then restart `npm run dev`.

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Sender address. Must use a verified domain in Resend, or the sandbox sender below
# (sandbox only delivers to the email you signed up with on Resend).
# LEAD_FROM_EMAIL=SMAESI Leads <notifications@smaesi.com>
LEAD_FROM_EMAIL=SMAESI Leads <onboarding@resend.dev>
